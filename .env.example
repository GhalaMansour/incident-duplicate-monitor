# =====================================================================
#  Incident Duplicate Monitor - Environment Variables
# =====================================================================
#  Copy this file to `.env` and fill in the values below. Never commit
#  the `.env` file. The values shown are placeholders.
# =====================================================================

# ---------------------------------------------------------------------
#  Maximo OSLC connection (required)
# ---------------------------------------------------------------------
#  The integration uses the in-house six-way endpoint/auth fallback
#  methodology documented in docs/maximo_oslc_methodology.md. A service
#  account with HTTP basic auth enabled is required.
# ---------------------------------------------------------------------

MAXIMO_BASE_URL=https://maximo.kidana.com.sa
MAXIMO_USER=
MAXIMO_PASS=
# Optional: restrict scans to a single site (Mina/Arafat/Muzdalifah).
MAXIMO_SITE_ID=

# ---------------------------------------------------------------------
#  Polling cadence
# ---------------------------------------------------------------------

# Interval between poll attempts, in seconds.
LM_POLL_SEC=15

# Lookback window for fetch_recent calls, in minutes.
LM_LOOKBACK_MIN=60

# Page size for OSLC requests. Maximo enforces a hard cap of 200.
LM_PAGE_SIZE=200

# HTTP request timeout, in seconds.
LM_TIMEOUT_SEC=20

# ---------------------------------------------------------------------
#  Source strategy
# ---------------------------------------------------------------------
#  auto   - try Maximo first, fall back to the file watcher after 3 fails
#  maximo - Maximo only
#  file   - file watcher only (offline/demo)
# ---------------------------------------------------------------------

LM_SOURCE_MODE=auto

# Folder to watch when the file source is active. Defaults to the bundled
# data/ directory.
LM_WATCH_DIR=

# ---------------------------------------------------------------------
#  Detection thresholds
# ---------------------------------------------------------------------

# Minimum score for a candidate pair to be retained.
LM_MIN_SCORE=7

# Maximum time gap (days) for a candidate pair to be considered.
LM_MAX_DAYS=2

# Score threshold above which an alert is raised.
LM_ALERT_SCORE=8

# ---------------------------------------------------------------------
#  Full-scan window
# ---------------------------------------------------------------------

# Quick scan interval, in seconds. The quick scan fetches only the
# newest page and is the dashboard's primary refresh signal.
LM_QUICK_SCAN_SEC=15

# Full scan interval, in seconds.
LM_SCAN_SEC=300

# Statuses to include in the full scan. Comma-separated. Empty means
# "all non-CLOSED statuses".
LM_OPEN_STATUSES=OPEN,NEW,QUEUED,INPRG,WPCOND,WAPPR,WMATL

# Optional ISO date bounds for the full scan.
LM_SCAN_START_DATE=
LM_SCAN_END_DATE=

# Rolling lookback window for the full scan, in days. The effective
# start is max(LM_SCAN_START_DATE, today - LM_FULL_SCAN_DAYS).
LM_FULL_SCAN_DAYS=2

# Hard page cap for fetch_all. At 200 rows per page, 15 pages covers
# the 3000 most recent SRs. Raise for deeper historical scans.
LM_FULL_SCAN_MAX_PAGES=15

# ---------------------------------------------------------------------
#  Dashboard
# ---------------------------------------------------------------------

# Port for the FastAPI dashboard. Managed platforms (Render) inject
# their own PORT variable, which takes precedence.
LM_PORT=8502

# ---------------------------------------------------------------------
#  Notifications (optional)
# ---------------------------------------------------------------------

# If set, every new alert is also POSTed to this URL as JSON.
LM_WEBHOOK_URL=

# In-app toast notifications.
LM_TOASTS=true

# Email recipients (comma-separated). Empty disables email.
LM_NOTIFY_EMAIL=
LM_SMTP_HOST=
LM_SMTP_PORT=587
LM_SMTP_USER=
LM_SMTP_PASS=
LM_SMTP_FROM=
LM_SMTP_TLS=true
