# =====================================================================
#  Python
# =====================================================================
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.eggs/

# =====================================================================
#  Virtual environments
# =====================================================================
.venv/
venv/
env/
ENV/

# =====================================================================
#  Tooling caches
# =====================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# =====================================================================
#  Secrets - never commit
# =====================================================================
.env
.env.*
!.env.example

# =====================================================================
#  Operational artifacts - excluded by design
# =====================================================================
# SQLite database file generated by the service
src/duplicate_monitor/monitor.db
*.db-journal

# Settings written by the dashboard settings page (Maximo credentials)
src/duplicate_monitor/user_settings.json

# Log files
src/duplicate_monitor/monitor.log
*.log

# Pickled scan results
*.pkl
src/duplicate_monitor/live_scan.pkl

# Uploaded XLSX/XLS workbooks
src/duplicate_monitor/web/uploaded.*

# User-decision snapshots
live_decisions.json
src/duplicate_monitor/web/live_decisions.json
decisions/
decisions*.json

# =====================================================================
#  Generated XLSX/XLS reports (operational data, not source)
# =====================================================================
*.xls
*.xlsx
~$*
# Keep the bundled reference XLS files under data/
!data/asset_description.xls
!data/location_description.xls

# =====================================================================
#  Word documents generated from the Markdown reports
# =====================================================================
# README.docx and REPORT.docx are committed as deliverables.
# Other .docx generated locally are not.
*.docx
!README.docx
!REPORT.docx

# =====================================================================
#  Local-only docs (kept on disk, never published)
# =====================================================================
README.local.md

# =====================================================================
#  Editors and OS noise
# =====================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
verify_window.py
